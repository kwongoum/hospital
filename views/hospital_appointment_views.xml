<odoo>

    <record id="view_hospital_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <!-- <tree string="Appointment Tree" delete="0"> -->
            <tree string="Appointment Tree"
                decoration-danger="state =='cancelled'"
                decoration-success="state=='done'"
                decoration-warning="state =='in_consultation'"
                decoration-info="state=='draft'"
            >
                <field name="patient_id" />
                <field name="description" />
                <field name="gender" widget="badge" />
                <field name="initial_doctor_id" widget="many2one_avatar_user" />
                <field name="state" widget="badge"
                    decoration-danger="state == 'cancelled'"
                    decoration-success="state == 'done'"
                    decoration-warning="state =='in_consultation'"
                    decoration-info="state=='draft'"
                />
                <field name="activity_ids" widget="list_activity" optional="show" />
                <field name="ref_appointment" />
                <field name="active" optional="show" />
                <field name="priority" widget="priority" optional="hide" />
                <field name="booking_date" optional="hide" />


            </tree>
        </field>
    </record>


    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>

        <field name="arch" type="xml">
            <!-- <form string="Appointment Form" edit="0" delete="0"> -->
            <form string="Appointment Form">
                <header>
                    <button name="create_doctor_user" type="object" string="Create Doctor User"
                        class="btn-primary"
                    />
                    <button name="action_reset_to_draft" type="object" string="Reset"
                        help="reset the appointment to draft state"
                        class="btn-secondary"
                    />

                    <button name="action_in_consultation" type="object" string="In Consultation"
                        attrs="{'invisible': [('state', 'in', ['done', 'cancelled'])]}"
                        class="btn-warning" />
                    <button name="action_done" type="object" string="Done" class="btn-primary"
                        attrs="{'invisible': [('state', 'in', ['done', 'cancelled'])]}"
                    />
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"
                        attrs="{'invisible': [('state', 'in', ['done', 'cancelled'])]}"
                        confirm="Are you sure you want to cancel this appointment?"
                    />


                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <div>
                        <group>
                            <field name="priority" />

                        </group>


                    </div>
                    <group>
                        <group>
                            <field name="patient_id" />
                            <field name="gender" />
                            <button name="action_open_patient" type="object"
                                string="patient details"
                                class="btn-info" />

                        </group>
                        <group>

                            <field name="booking_date" />
                            <field name="appointment_date" />
                            <field name="initial_doctor_id" />
                        </group>

                        <group>
                            <field name="ref_appointment" />
                            <field name="active" />
                        </group>
                    </group>
                    <notebook>

                        <page string="Description" name="description">
                            <group>
                                <field name="description" />
                            </group>
                        </page>

                        <page string="Prescription" name="prescription">
                            <field name="prescription" placeholder="Enter prescription details..."
                                options="{'collaborative':True, 'resizable':True }"
                            />
                        </page>
                        <page string="Pharmacy" name="pharmacy">

                        </page>

                    </notebook>
                </sheet>
                <!-- CHATTTER -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>


    <record id="action_hospital_appointments" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="view_hospital_appointment_tree" />

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first appointment!
            </p>
        </field>
    </record>

</odoo>