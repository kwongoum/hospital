<odoo>


    <record id="view_hospital_patient_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search string="Patients">
                <field name="name" />
                <separator />
                <filter string="Female" name="patient_female"
                    domain="[('gender', '=', 'female')]" />
                <separator />
                <filter string="Child" name="patient_child" domain="[('age','&lt;', 7)]"
                />
                <filter name="archived"
                    string="Archived"
                    domain="[('active', '=', False)]" />
                <group expand="1" string="Group By">
                    <filter string="Gender" name='group_by_gender'
                        context="{'group_by':'gender'}" />
                    <filter string="Age" name='group_by_age'
                        context="{'group_by':'age'}" />
                </group>
                <searchpanel>
                    <field name="gender" string="Gender" enable_counters="1" icon="fa-users"
                        select="multi" />
                </searchpanel>
            </search>
        </field>
    </record>


    <record id="view_hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree string="Patient Tree" sample="1">
                <field name="name" />
                <field name="age" />
                <field name="address" />
                <field name="gender" />
                <field name="ref_patient" />
                <field name="active" />

            </tree>
        </field>
    </record>


    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>

        <field name="arch" type="xml">
            <form string="Patient Form">
                <sheet>

                    <group>
                        <group>
                            <field name="name" autofocus="1" />
                            <field name="date_of_birth" />
                            <field name="age" />
                            <field name="ref_patient" />
                        </group>
                        <group>
                            <field name="gender" />
                            <field name="address" />
                            <field name="active" help="Inactive patients will not appear in lists" />
                        </group>
                    </group>

                </sheet>
                <!-- CHATTTER -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="message_ids" widget="mail_thread" />
                    <field name="activity_ids" widget="mail_activity" />
                </div>
            </form>
        </field>
    </record>

    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients list_ac</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="view_hospital_patient_tree" />

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first patient!
            </p>
        </field>
        <field name="context">
            {
            'search_default_patient_male':1,
            'search_default_group_by_gender': 1
            }
        </field>

        <field name="search_view_id" ref="view_hospital_patient_search" />
    </record>

    <record id="action_hospital_patient_kanban" model="ir.actions.act_window">
        <field name="name">Patients_kanban_ac</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">kanban,tree,form</field>

    </record>

</odoo>