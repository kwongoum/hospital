<odoo>
    <data>
        <record id="view_hospital_patient_tag_tree" model="ir.ui.view">
            <field name="name">hospital.patient.tag.tree</field>
            <field name="model">hospital.patient.tag</field>
            <field name="arch" type="xml">
                <tree string="Patient Tag Tree" sample="1">
                    <field name="name" />
                    <field name="color" widget="color_picker" />
                    <field name="active" />
                </tree>
            </field>
        </record>
        <record id="view_hospital_patient_tag_form" model="ir.ui.view">
            <field name="name">hospital.patient.tag.form</field>
            <field name="model">hospital.patient.tag</field>
            <field name="arch" type="xml">
                <form string="Patient Tag Form" sample="1">
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="color" widget="color_picker" />
                            <field name="active" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_hospital_patient_tag" model="ir.actions.act_window">
            <field name="name">Patient Tags</field>
            <field name="res_model">hospital.patient.tag</field>
            <field name="view_mode">tree,form</field>

            <field name="view_id" ref="view_hospital_patient_tag_tree" />
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create patient tags to categorize patients.
                </p>
            </field>

        </record>
    </data>
</odoo>