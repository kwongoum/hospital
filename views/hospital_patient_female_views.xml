<odoo>

    <record id="view_hospital_patient_female_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search string="Patients">
                <field name="name" />
                <separator />
                <filter string="Male" name="patient_male"
                    domain="[('gender', '=', 'male')]" />
                <filter string="Female" name="patient_female"
                    domain="[('gender', '=', 'female')]" />
                <separator />
                <filter string="Child" name="patient_child" domain="[('age','&lt;', 7)]"
                />
                <filter name="archived"
                    string="Archived"
                    domain="[('active', '=', False)]" />
                <group expand="1" string="Group By">
                    <filter string="Gender" name='group_by_gender'
                        context="{'group_by':'gender'}" />
                    <filter string="Age" name='group_by_age'
                        context="{'group_by':'age'}" />

                </group>
            </search>
        </field>
    </record>


    <record id="view_hospital_patient_female_tree" model="ir.ui.view">
        <field name="name">hospital.patient.female.tree</field>
        <field name="model">hospital.patient</field>
        <field name="inherit_id" ref="view_hospital_patient_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="age" />
            </xpath>
        </field>
    </record>


    <record id="view_hospital_patient_female_form" model="ir.ui.view">
        <field name="name">hospital.patient.female.form</field>
        <field name="model">hospital.patient</field>
        <field name="inherit_id" ref="view_hospital_patient_form" />

        <field name="arch" type="xml">


            <xpath expr="//field[@name='gender']" position="after">
                <field name="age" />
            </xpath>


        </field>
    </record>

    <record id="action_hospital_patient_female" model="ir.actions.act_window">
        <field name="name">Patients female</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_hospital_patient_female_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first patient female !
            </p>
        </field>
        <field name="domain"> [('gender','=','female')]</field>
        <field name="context"> {
            'default_gender':'female',
            'default_age': 25
            }</field>


        <field name="search_view_id" ref="view_hospital_patient_female_search" />
    </record>


</odoo>